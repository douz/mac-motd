{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "none",
  },
  "modules": [
    "os",
    "host",
    "kernel",
    "uptime",
    {
      "type": "cpu",
      "temp": true,
    },
    {
      "type": "gpu",
      "temp": true,
    },
    "memory",
    "disk",
  ],
}
